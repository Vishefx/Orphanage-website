<title>Well Dancers Orphanage | Kampala, Uganda</title>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --sage:#4a7c59;
  --sage-light:#6a9e78;
  --sage-pale:#eef4f0;
  --slate:#2c3e50;
  --slate-mid:#3d5166;
  --slate-light:#5a7384;
  --cream:#faf8f5;
  --cream-dark:#f0ece5;
  --warm:#e8ddd0;
  --gold:#b8860b;
  --gold-light:#d4a017;
  --white:#ffffff;
  --text:#2c3e50;
  --text-mid:#5a7384;
  --text-light:#8fa3b1;
  --shadow:rgba(44,62,80,0.1);
  --shadow-md:rgba(44,62,80,0.15);
}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--cream)}
::-webkit-scrollbar-thumb{background:var(--sage);border-radius:3px}

/* ── NAV ── */
nav{
position:fixed;top:0;left:0;right:0;z-index:200;
display:flex;align-items:center;justify-content:space-between;
padding:1.1rem 4rem;
background:rgba(250,248,245,0.97);
backdrop-filter:blur(12px);
border-bottom:1px solid var(–warm);
box-shadow:0 2px 20px var(–shadow);
}
.nav-logo{
display:flex;align-items:center;gap:.8rem;
font-family:‘Libre Baskerville’,serif;
font-size:1.25rem;font-weight:700;color:var(–slate);
}
.nav-logo .cross{
width:32px;height:32px;background:var(–sage);border-radius:6px;
display:flex;align-items:center;justify-content:center;
color:#fff;font-size:.9rem;flex-shrink:0;
}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{
text-decoration:none;color:var(–text-mid);
font-size:.82rem;font-weight:500;letter-spacing:.04em;
transition:color .2s;
}
.nav-links a:hover{color:var(–sage)}
.nav-cta{
background:var(–sage);color:#fff;border:none;
padding:.65rem 1.5rem;border-radius:6px;
font-family:‘Inter’,sans-serif;font-weight:600;font-size:.8rem;
letter-spacing:.04em;cursor:pointer;
box-shadow:0 3px 12px rgba(74,124,89,.3);
transition:all .2s;
}
.nav-cta:hover{background:var(–sage-light);transform:translateY(-1px);box-shadow:0 5px 18px rgba(74,124,89,.35)}

/* ── HERO ── */
.hero{
min-height:100vh;display:flex;align-items:center;
background:linear-gradient(150deg,#f5f8f5 0%,#eef4f0 40%,#f0ece5 100%);
position:relative;overflow:hidden;
}
.hero::before{
content:’’;position:absolute;top:-20%;right:-10%;
width:60vw;height:120vh;
background:radial-gradient(ellipse at 60% 40%,rgba(74,124,89,.08) 0%,transparent 70%);
border-radius:50%;pointer-events:none;
}
.hero::after{
content:’’;position:absolute;bottom:-10%;left:-5%;
width:40vw;height:60vh;
background:radial-gradient(ellipse,rgba(184,134,11,.06) 0%,transparent 70%);
border-radius:50%;pointer-events:none;
}
.hero-inner{
display:grid;grid-template-columns:1fr 1fr;
gap:5rem;align-items:center;
max-width:1200px;margin:0 auto;
padding:9rem 4rem 6rem;width:100%;
position:relative;z-index:1;
}
.hero-eyebrow{
display:inline-flex;align-items:center;gap:.6rem;
font-size:.72rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;
color:var(–sage);margin-bottom:1.4rem;
}
.hero-eyebrow::before{content:’’;display:block;width:28px;height:1.5px;background:var(–sage)}
.hero h1{
font-family:‘Libre Baskerville’,serif;
font-size:clamp(2.2rem,4.5vw,3.6rem);
font-weight:700;line-height:1.15;
color:var(–slate);margin-bottom:1rem;
}
.hero h1 em{color:var(–sage);font-style:italic}
.hero-ministry{
font-family:‘Libre Baskerville’,serif;
font-size:1.05rem;font-style:italic;
color:var(–gold);margin-bottom:1.4rem;letter-spacing:.02em;
}
.hero p{
font-size:.97rem;color:var(–text-mid);
line-height:1.9;max-width:460px;margin-bottom:2.2rem;
font-weight:300;
}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap}
.btn-sage{
background:var(–sage);color:#fff;
padding:.9rem 2rem;border-radius:6px;border:none;
font-family:‘Inter’,sans-serif;font-weight:600;font-size:.85rem;
cursor:pointer;text-decoration:none;display:inline-block;
box-shadow:0 4px 16px rgba(74,124,89,.3);transition:all .2s;
}
.btn-sage:hover{background:var(–sage-light);transform:translateY(-2px);box-shadow:0 8px 24px rgba(74,124,89,.35)}
.btn-outline-slate{
background:transparent;color:var(–slate);
padding:.9rem 2rem;border-radius:6px;
border:1.5px solid var(–warm);
font-family:‘Inter’,sans-serif;font-weight:600;font-size:.85rem;
cursor:pointer;text-decoration:none;display:inline-block;transition:all .2s;
}
.btn-outline-slate:hover{border-color:var(–sage);color:var(–sage)}

/* Hero image mosaic */
.hero-mosaic{
display:grid;grid-template-columns:1fr 1fr;
grid-template-rows:200px 200px;gap:.75rem;
}
.hm-img{
border-radius:12px;overflow:hidden;
box-shadow:0 8px 28px var(–shadow-md);
position:relative;
}
.hm-img img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease}
.hm-img:hover img{transform:scale(1.04)}
.hm-img:first-child{grid-row:span 2;border-radius:16px}
.hm-tag{
position:absolute;bottom:.75rem;left:.75rem;
background:rgba(250,248,245,.92);
color:var(–slate);font-size:.65rem;font-weight:600;
letter-spacing:.08em;text-transform:uppercase;
padding:.25rem .65rem;border-radius:4px;
border-left:3px solid var(–sage);
}

/* ── STATS ── */
.stats-bar{
background:var(–slate);
padding:2.8rem 4rem;
display:grid;grid-template-columns:repeat(4,1fr);
gap:1rem;text-align:center;
}
.stat-n{
font-family:‘Libre Baskerville’,serif;
font-size:2.6rem;font-weight:700;color:var(–cream);line-height:1;
}
.stat-n span{color:var(–gold-light)}
.stat-l{
font-size:.72rem;color:rgba(255,255,255,.5);
margin-top:.4rem;letter-spacing:.1em;text-transform:uppercase;font-weight:500;
}

/* ── SHARED SECTION ── */
section{padding:6rem 4rem}
.sec-inner{max-width:1200px;margin:0 auto}
.pill{
display:inline-flex;align-items:center;gap:.5rem;
font-size:.7rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
color:var(–sage);margin-bottom:.7rem;
}
.pill::before{content:’’;display:block;width:22px;height:1.5px;background:var(–sage)}
.sec-title{
font-family:‘Libre Baskerville’,serif;
font-size:clamp(1.8rem,3vw,2.5rem);font-weight:700;
line-height:1.2;color:var(–slate);margin-bottom:1rem;
}
.sec-title em{color:var(–sage);font-style:italic}
.rule{width:44px;height:2px;background:var(–sage);margin:1rem 0 1.5rem;border-radius:1px}
.sec-body{color:var(–text-mid);font-size:.96rem;line-height:1.9;font-weight:300;max-width:540px}

/* ── ABOUT ── */
.about-sec{background:var(–white)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.about-cards{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.ac{
background:var(–cream);border-radius:12px;padding:1.6rem;
border:1px solid var(–cream-dark);
transition:all .3s;
}
.ac:hover{background:var(–sage-pale);border-color:rgba(74,124,89,.2);transform:translateY(-3px);box-shadow:0 8px 24px var(–shadow)}
.ac-icon{font-size:1.7rem;margin-bottom:.7rem}
.ac h4{font-family:‘Libre Baskerville’,serif;font-size:.95rem;font-weight:700;color:var(–slate);margin-bottom:.4rem}
.ac p{font-size:.8rem;color:var(–text-mid);line-height:1.75}

/* ── NEEDS ── */
.needs-sec{background:var(–cream)}
.needs-header{text-align:center;margin-bottom:3rem}
.needs-header .rule{margin:1rem auto 1.5rem}
.needs-header .sec-body{margin:0 auto}
.needs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem}
.need-card{
background:var(–white);border-radius:14px;padding:2rem;
border:1px solid var(–cream-dark);
box-shadow:0 2px 12px var(–shadow);
position:relative;overflow:hidden;
transition:all .3s;
}
.need-card::after{
content:’’;position:absolute;top:0;left:0;right:0;height:3px;
background:var(–sage);
}
.need-card:hover{transform:translateY(-5px);box-shadow:0 16px 40px var(–shadow-md)}
.need-icon{font-size:2.2rem;margin-bottom:1rem;display:block}
.need-card h3{font-family:‘Libre Baskerville’,serif;font-size:1.05rem;font-weight:700;color:var(–slate);margin-bottom:.6rem}
.need-card p{font-size:.82rem;color:var(–text-mid);line-height:1.8}
.need-badge{
display:inline-block;margin-top:1rem;
background:var(–sage-pale);color:var(–sage);
font-size:.72rem;font-weight:600;
padding:.3rem .8rem;border-radius:4px;
border:1px solid rgba(74,124,89,.2);
}

/* ── GALLERY ── */
.gallery-sec{background:var(–white)}
.gallery-grid{
display:grid;
grid-template-columns:repeat(4,1fr);
grid-auto-rows:230px;
gap:.75rem;margin-top:2.5rem;
}
.gal-item{
border-radius:10px;overflow:hidden;cursor:pointer;
position:relative;background:var(–cream-dark);
box-shadow:0 3px 14px var(–shadow);
}
.gal-item:nth-child(1){grid-column:span 2;grid-row:span 2}
.gal-item:nth-child(6){grid-column:span 2}
.gal-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .45s ease}
.gal-item:hover img{transform:scale(1.06)}
.gal-overlay{
position:absolute;inset:0;
background:linear-gradient(0deg,rgba(44,62,80,.75) 0%,transparent 55%);
display:flex;align-items:flex-end;padding:1rem;
opacity:0;transition:opacity .3s;
}
.gal-item:hover .gal-overlay{opacity:1}
.gal-overlay span{font-size:.76rem;color:#fff;font-weight:500;line-height:1.45}

/* ── DONATE ── */
.donate-sec{background:var(–slate)}
.donate-inner{
max-width:1200px;margin:0 auto;
display:grid;grid-template-columns:1fr 1.05fr;gap:5rem;align-items:start;
}
.donate-info .pill{color:rgba(255,255,255,.5)}
.donate-info .pill::before{background:rgba(255,255,255,.4)}
.donate-info .sec-title{color:var(–cream)}
.donate-info .sec-title em{color:var(–gold-light)}
.donate-info .rule{background:var(–gold-light)}
.donate-info .sec-body{color:rgba(255,255,255,.55)}

.give-list{display:flex;flex-direction:column;gap:.85rem;margin-top:2rem}
.gi{
display:flex;gap:1rem;align-items:flex-start;
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.09);
border-radius:10px;padding:1.1rem 1.3rem;
}
.gi-icon{
width:36px;height:36px;border-radius:8px;
background:rgba(74,124,89,.35);
display:flex;align-items:center;justify-content:center;
font-size:.95rem;flex-shrink:0;
}
.gi p{font-size:.85rem;color:rgba(255,255,255,.65);line-height:1.7}
.gi p strong{color:var(–cream)}

.donate-box{
background:var(–cream);border-radius:16px;padding:2.5rem;
box-shadow:0 20px 50px rgba(0,0,0,.2);
}
.donate-box h3{
font-family:‘Libre Baskerville’,serif;
font-size:1.6rem;font-weight:700;color:var(–slate);margin-bottom:.3rem;
}
.donate-box>p{font-size:.84rem;color:var(–text-mid);margin-bottom:2rem}
.amount-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.75rem;margin-bottom:1.5rem}
.amt{
background:var(–white);border:1.5px solid var(–cream-dark);
border-radius:10px;padding:.9rem;text-align:center;cursor:pointer;transition:all .25s;
}
.amt:hover,.amt.active{border-color:var(–sage);background:var(–sage-pale);box-shadow:0 0 0 3px rgba(74,124,89,.12)}
.amt-n{font-family:‘Libre Baskerville’,serif;font-size:1.3rem;font-weight:700;color:var(–sage)}
.amt-l{font-size:.7rem;color:var(–text-mid);margin-top:.2rem}
.fg{margin-bottom:1rem}
.fg label{display:block;font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(–text-mid);margin-bottom:.4rem}
.fg input,.fg select{
width:100%;background:var(–white);
border:1.5px solid var(–cream-dark);border-radius:8px;
padding:.72rem 1rem;color:var(–text);font-family:‘Inter’,sans-serif;
font-size:.9rem;outline:none;transition:border-color .2s;
}
.fg input:focus,.fg select:focus{border-color:var(–sage)}
.fg select{appearance:none;cursor:pointer}
.wa-btn2{
display:flex;align-items:center;justify-content:center;gap:.75rem;
width:100%;background:#25D366;color:#fff;border:none;
padding:1.05rem;border-radius:8px;
font-family:‘Inter’,sans-serif;font-weight:700;font-size:.9rem;
cursor:pointer;transition:all .2s;margin-top:.4rem;
box-shadow:0 4px 16px rgba(37,211,102,.3);text-decoration:none;
}
.wa-btn2:hover{background:#1db954;transform:translateY(-1px);box-shadow:0 8px 24px rgba(37,211,102,.35)}
.divider-or{text-align:center;color:var(–text-light);font-size:.78rem;margin:.75rem 0;position:relative}
.divider-or::before,.divider-or::after{content:’’;position:absolute;top:50%;width:44%;height:1px;background:var(–cream-dark)}
.divider-or::before{left:0}.divider-or::after{right:0}
.email-btn{
display:flex;align-items:center;justify-content:center;gap:.75rem;
width:100%;background:var(–white);color:var(–slate);
border:1.5px solid var(–cream-dark);
padding:1rem;border-radius:8px;
font-family:‘Inter’,sans-serif;font-weight:600;font-size:.85rem;
cursor:pointer;transition:all .2s;text-decoration:none;
}
.email-btn:hover{border-color:var(–sage);color:var(–sage)}
.secure-note{text-align:center;margin-top:.9rem;font-size:.72rem;color:var(–text-light)}

/* ── CONTACT ── */
.contact-sec{background:var(–cream)}
.contact-grid{display:grid;grid-template-columns:1fr 1.1fr;gap:5rem;align-items:start}
.contact-info-cards{display:flex;flex-direction:column;gap:.9rem;margin-top:2rem}
.cic{
display:flex;gap:1rem;align-items:flex-start;
background:var(–white);border:1px solid var(–cream-dark);
border-radius:12px;padding:1.2rem 1.4rem;
box-shadow:0 2px 10px var(–shadow);
transition:all .3s;
}
.cic:hover{border-color:rgba(74,124,89,.25);transform:translateX(4px)}
.cic-icon{
width:40px;height:40px;border-radius:8px;flex-shrink:0;
background:var(–sage-pale);border:1px solid rgba(74,124,89,.15);
display:flex;align-items:center;justify-content:center;font-size:1rem;
}
.cic-text h5{font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(–sage);margin-bottom:.25rem}
.cic-text p{font-size:.9rem;color:var(–slate);font-weight:500}
.cic-text a{color:var(–slate);text-decoration:none;transition:color .2s}
.cic-text a:hover{color:var(–sage)}

/* Social links */
.social-row{display:flex;gap:.75rem;margin-top:1.5rem;flex-wrap:wrap}
.soc-link{
display:inline-flex;align-items:center;gap:.5rem;
background:var(–white);border:1.5px solid var(–cream-dark);
color:var(–text-mid);padding:.6rem 1.1rem;border-radius:8px;
font-size:.8rem;font-weight:600;text-decoration:none;
transition:all .2s;
}
.soc-link:hover{border-color:var(–sage);color:var(–sage)}
.soc-link.tiktok:hover{border-color:#000;color:#000}
.soc-link.fb:hover{border-color:#1877f2;color:#1877f2}
.soc-coming{font-size:.72rem;color:var(–text-light);font-style:italic;align-self:center}

.contact-form-box{
background:var(–white);border:1px solid var(–cream-dark);
border-radius:16px;padding:2.5rem;
box-shadow:0 4px 24px var(–shadow);
}
.contact-form-box h3{
font-family:‘Libre Baskerville’,serif;
font-size:1.5rem;font-weight:700;color:var(–slate);margin-bottom:.3rem;
}
.contact-form-box>p{font-size:.84rem;color:var(–text-mid);margin-bottom:1.8rem}
.fg textarea{
width:100%;background:var(–cream);
border:1.5px solid var(–cream-dark);border-radius:8px;
padding:.72rem 1rem;color:var(–text);font-family:‘Inter’,sans-serif;
font-size:.9rem;outline:none;transition:border-color .2s;
resize:vertical;min-height:110px;
}
.fg textarea:focus{border-color:var(–sage)}
.contact-submit{
width:100%;background:var(–sage);color:#fff;border:none;
padding:1.05rem;border-radius:8px;
font-family:‘Inter’,sans-serif;font-weight:700;font-size:.88rem;
cursor:pointer;transition:all .2s;margin-top:.3rem;
box-shadow:0 4px 14px rgba(74,124,89,.3);
}
.contact-submit:hover{background:var(–sage-light);transform:translateY(-1px);box-shadow:0 8px 22px rgba(74,124,89,.35)}
.suc{
display:none;background:var(–sage-pale);border:1px solid rgba(74,124,89,.25);
border-radius:8px;padding:1rem;text-align:center;
color:var(–sage);font-size:.86rem;margin-top:.8rem;font-weight:500;
}

/* ── LIGHTBOX ── */
.lightbox{display:none;position:fixed;inset:0;z-index:500;background:rgba(20,28,36,.96);backdrop-filter:blur(8px);align-items:center;justify-content:center}
.lightbox.open{display:flex}
.lb-inner{position:relative;max-width:90vw;max-height:90vh;text-align:center}
.lb-inner img{max-width:88vw;max-height:80vh;border-radius:10px;object-fit:contain}
.lb-cap{color:rgba(255,255,255,.6);font-size:.82rem;margin-top:.8rem;font-style:italic}
.lb-close{position:fixed;top:1.5rem;right:1.5rem;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:#fff;width:40px;height:40px;border-radius:8px;font-size:1.1rem;cursor:pointer;transition:background .2s}
.lb-close:hover{background:rgba(255,255,255,.15)}
.lb-prev,.lb-next{position:fixed;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:#fff;width:48px;height:48px;border-radius:8px;font-size:1.3rem;cursor:pointer;transition:background .2s}
.lb-prev{left:1.5rem}.lb-next{right:1.5rem}
.lb-prev:hover,.lb-next:hover{background:rgba(74,124,89,.5)}

/* ── FOOTER ── */
footer{
background:var(–slate);
padding:3.5rem 4rem 2rem;
}
.footer-top{display:grid;grid-template-columns:1.8fr 1fr 1fr;gap:3.5rem;margin-bottom:2.5rem}
.fb-logo{
font-family:‘Libre Baskerville’,serif;
font-size:1.25rem;font-weight:700;color:var(–cream);
display:flex;align-items:center;gap:.6rem;margin-bottom:1rem;
}
.fb-logo .dot{width:8px;height:8px;background:var(–sage-light);border-radius:50%;flex-shrink:0}
.fb-p{font-size:.82rem;color:rgba(255,255,255,.45);line-height:1.85}
.fc h6{font-size:.68rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(–sage-light);margin-bottom:1.1rem}
.fc ul{list-style:none}
.fc ul li{margin-bottom:.65rem}
.fc ul li a{text-decoration:none;color:rgba(255,255,255,.45);font-size:.83rem;transition:color .2s}
.fc ul li a:hover{color:rgba(255,255,255,.85)}
.footer-bot{
border-top:1px solid rgba(255,255,255,.07);
padding-top:1.5rem;text-align:center;
font-size:.74rem;color:rgba(255,255,255,.3);
}

/* Floating WA */
.float-wa{
position:fixed;bottom:2rem;right:2rem;z-index:300;
width:52px;height:52px;background:#25D366;border-radius:50%;
display:flex;align-items:center;justify-content:center;font-size:1.5rem;
